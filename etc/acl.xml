<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="SoftCommerce_Core::softcommerce_core">
                    <resource id="SoftCommerce_Profile::profile">
                        <resource id="SoftCommerce_ProfileNotification::notification" title="Profile Notifications" translate="title" sortOrder="100">
                            <resource id="SoftCommerce_ProfileNotification::notification_view" title="View Notifications" translate="title" sortOrder="10"/>
                            <resource id="SoftCommerce_ProfileNotification::notification_delete" title="Delete Notifications" translate="title" sortOrder="20"/>
                            <resource id="SoftCommerce_ProfileNotification::notification_summary" title="View Process Summary" translate="title" sortOrder="30"/>
                        </resource>
                    </resource>
                </resource>
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="SoftCommerce_ProfileNotification::config" title="Profile Notification Configuration" translate="title"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
